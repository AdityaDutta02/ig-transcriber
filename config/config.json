{
  "input": {
    "csv_path": "data/input/reels.csv",
    "url_column": "url",
    "skip_processed": true,
    "validate_urls": true
  },
  "download": {
    "concurrent_workers": 12,
    "timeout": 30,
    "retry_attempts": 3,
    "retry_delay": 2,
    "rate_limit_delay": 0.5,
    "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "format": "bestaudio",
    "extract_audio": true,
    "audio_format": "wav",
    "audio_quality": "0"
  },
  "transcription": {
    "api_provider": "groq",
    "language": "auto"
  },
  "captions": {
    "enabled": true,
    "words_per_line": 10,
    "max_lines": 2,
    "format": "srt"
  },
  "output": {
    "directory": "data/output/transcriptions",
    "format": "txt",
    "encoding": "utf-8",
    "naming_pattern": "{timestamp}_{id}",
    "include_metadata": true,
    "metadata": ["url", "timestamp", "duration", "language", "api_provider", "processing_time"]
  },
  "processing": {
    "batch_size": 100,
    "temp_directory": "data/temp",
    "cleanup_temp": true,
    "save_checkpoint": true,
    "checkpoint_interval": 10,
    "checkpoint_file": "logs/checkpoint.json"
  },
  "logging": {
    "level": "INFO",
    "console": true,
    "file": "logs/app.log",
    "max_file_size": "10MB",
    "backup_count": 5,
    "format": "{time:YYYY-MM-DD HH:mm:ss} | {level: <8} | {message}",
    "error_file": "logs/errors.log"
  },
  "monitoring": {
    "enabled": true,
    "track_metrics": true,
    "report_interval": 30,
    "save_report": true,
    "report_path": "data/output/reports"
  },
  "error_handling": {
    "continue_on_error": true,
    "max_consecutive_errors": 5,
    "save_failed_urls": true,
    "failed_urls_path": "logs/failed_urls.txt",
    "exponential_backoff": true,
    "max_backoff_time": 60
  }
}
