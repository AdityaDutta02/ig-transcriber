# Instagram Reel Transcriber - Environment Variables
# Copy this file to .env and configure as needed

# Project Configuration
PROJECT_NAME="Instagram Reel Transcriber"
ENVIRONMENT="development"  # development, production, testing

# Paths
CONFIG_PATH="config/config.yaml"
DATA_DIR="data"
LOGS_DIR="logs"

# API Keys
GROQ_API_KEY=gsk_...
RAPIDAPI_KEY=...

# Authentication (optional — if none set, app runs without login)
# Google OAuth: create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Email/password auth: semicolon-separated email:bcrypt_hash pairs
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
AUTH_CREDENTIALS=

# Performance Tuning
MAX_WORKERS=12  # Maximum number of download workers

# Optional: Proxy Configuration (if needed)
# HTTP_PROXY=""
# HTTPS_PROXY=""

# Optional: Cloud Storage (Phase 4)
# GCP_PROJECT_ID=""
# GCP_BUCKET_NAME=""
# AWS_REGION=""
# AWS_BUCKET_NAME=""

# Optional: API Configuration (Phase 3)
# API_HOST="0.0.0.0"
# API_PORT=8000
# API_KEY=""

# Debug Settings
DEBUG=false
VERBOSE=false
