# Instagram Reel Transcriber - Environment Variables
# Copy this file to .env and configure as needed

# Project Configuration
PROJECT_NAME="Instagram Reel Transcriber"
ENVIRONMENT="development"  # development, production, testing

# Paths
CONFIG_PATH="config/config.yaml"
DATA_DIR="data"
LOGS_DIR="logs"

# GPU Configuration
CUDA_VISIBLE_DEVICES=0  # GPU device ID (0 for first GPU, -1 for CPU only)

# Performance Tuning
MAX_WORKERS=12  # Maximum number of download workers
WHISPER_MODEL="base"  # Whisper model to use

# Optional: Proxy Configuration (if needed)
# HTTP_PROXY=""
# HTTPS_PROXY=""

# Optional: Cloud Storage (Phase 4)
# GCP_PROJECT_ID=""
# GCP_BUCKET_NAME=""
# AWS_REGION=""
# AWS_BUCKET_NAME=""

# Optional: API Configuration (Phase 3)
# API_HOST="0.0.0.0"
# API_PORT=8000
# API_KEY=""

# Debug Settings
DEBUG=false
VERBOSE=false
